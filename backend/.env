# ─────────────────────────────────────────────────────
# Configurações do backend – Flask
# ─────────────────────────────────────────────────────

# Chave secreta para sessões Flask (troque por uma string aleatória longa)
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_ALEATORIA

# URI do banco de dados (SQLite por padrão, não precisa alterar)
DATABASE_URL=sqlite:///minha_estante.db

# Origem permitida pelo CORS (URL do seu frontend Next.js)
FRONTEND_ORIGIN=http://localhost:3000
